#!/bin/bash
# This hook is run after a new virtualenv is activated.

# Install pytest so that tests run inside the virtual environment

pip install --ignore-installed pytest

# Site-specific: fix macOS virtualenv for Python 2 so that matplotlib works
# with its Cocoa backend (requires fix-osx-virtualenv from virtualenv-pythonw-osx).
# Python 2 is EOL; remove this block if not needed in your environment.
# See https://github.com/gldnspud/virtualenv-pythonw-osx/issues/12

python_major_version=`python -c "import sys; print(sys.version_info.major)"`

if [ "$python_major_version" == "2" ]; then
    echo ""
    echo "Fixing virtual environment to contain a Python app bundle"
    fix-osx-virtualenv $VIRTUAL_ENV
fi

# For all python versions: include baseenv packages.
# bootstrap_virtualenv.sh is expected to live in $WORKON_HOME alongside this hook.
$WORKON_HOME/bootstrap_virtualenv.sh
